# WiFi AutoInterface — automatic LAN discovery
# Works on any WiFi network without any configuration
# Nodes on the same LAN will discover each other automatically via UDP multicast

[reticulum]
enable_transport = no
share_instance = yes
shared_instance_port = 37428
instance_control_port = 37429
panic_on_interface_error = no

[logging]
loglevel = 4

[interfaces]

  [[AutoInterface]]
  type = AutoInterface
  enabled = yes
  # Optionally restrict to specific interfaces:
  # devices = wlan0, eth0
