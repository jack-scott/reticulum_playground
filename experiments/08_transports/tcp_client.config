# TCP Client — this node connects OUT to a server
# Edit target_host to point at the server machine's IP

[reticulum]
enable_transport = no
share_instance = yes
shared_instance_port = 37430
instance_control_port = 37431
panic_on_interface_error = no

[logging]
loglevel = 4

[interfaces]

  [[AutoInterface]]
  type = AutoInterface
  enabled = yes

  [[TCPClientInterface]]
  type = TCPClientInterface
  enabled = yes
  target_host = 192.168.1.10   # EDIT: IP of the TCP server
  target_port = 4242
  # Optional: passphrase must match server
  # passphrase = change_me
